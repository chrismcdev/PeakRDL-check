#!/bin/bash
# Regenerate the deterministic benchmark fixtures (not committed; manifests are).
set -euo pipefail
cd "$(dirname "$0")/.."
F=.venv/bin/regreview-fixture
G=fixtures/generated
$F generate --registers 1000   --blocks 8   --seed 12345 --name bench1k   --output $G/1k.rdl
$F generate --registers 10000  --blocks 16  --seed 12346 --name bench10k  --output $G/10k.rdl
$F generate --registers 100000 --blocks 100 --seed 12347 --name bench100k --output $G/100k.rdl
$F generate --registers 400000 --blocks 400 --duplicate-ratio 0.4 --hierarchy-depth 4 --seed 12348 --name bench400k --output $G/400k.rdl
$F generate --registers 800000 --blocks 800 --duplicate-ratio 0.4 --hierarchy-depth 4 --seed 12345 --name bench800k --output $G/800k.rdl
$F generate --registers 10000  --blocks 16 --duplicate-ratio 0 --array-ratio 0 --seed 999 --name uniq10k --output $G/uniq10k.rdl
for m in $G/*.manifest.json; do $F verify "$m" | tail -1; done
cp $G/*.manifest.json fixtures/manifests/
